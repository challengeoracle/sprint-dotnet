@page
@model LoginModel

@{
    ViewData["Title"] = "Entrar";
    Layout = "~/Areas/Identity/Pages/Account/_AuthLayout.cshtml";
}

<div class="auth-form-box">

    <div class="auth-form-header">
        <h1 class="auth-form-title">Bem-vindo de volta</h1>
        <p class="auth-form-subtitle">Acesse sua conta para continuar.</p>
    </div>

    <form id="account" method="post">
        <div asp-validation-summary="ModelOnly" class="auth-error-summary" role="alert"></div>

        <div class="form-group">
            <label asp-for="Input.Email">E-mail</label>
            <div class="input-icon-wrap">
                <i class="bi bi-envelope input-icon"></i>
                <input asp-for="Input.Email" class="form-control form-control-icon"
                       autocomplete="username" placeholder="seuemail@exemplo.com" />
            </div>
            <span asp-validation-for="Input.Email" class="text-danger"></span>
        </div>

        <div class="form-group">
            <label asp-for="Input.Password">Senha</label>
            <div class="input-icon-wrap">
                <i class="bi bi-lock input-icon"></i>
                <input asp-for="Input.Password" class="form-control form-control-icon"
                       autocomplete="current-password" placeholder="Digite sua senha" />
            </div>
            <span asp-validation-for="Input.Password" class="text-danger"></span>
        </div>

        <div class="auth-remember-row">
            <div class="form-check">
                <input class="form-check-input" asp-for="Input.RememberMe" />
                <label class="form-check-label" asp-for="Input.RememberMe">Lembrar de mim</label>
            </div>
        </div>

        <button id="login-submit" type="submit" class="btn btn-primary btn-auth-submit">
            Entrar <i class="bi bi-arrow-right ms-1"></i>
        </button>
    </form>

    @if ((Model.ExternalLogins?.Count ?? 0) > 0)
    {
        <div class="auth-divider"><span>ou continue com</span></div>
        <form id="external-account" asp-page="./ExternalLogin" asp-route-returnUrl="@Model.ReturnUrl" method="post">
            @foreach (var provider in Model.ExternalLogins!)
            {
                <button type="submit" class="btn btn-secondary w-100 mt-2" name="provider" value="@provider.Name">
                    @provider.DisplayName
                </button>
            }
        </form>
    }

</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
